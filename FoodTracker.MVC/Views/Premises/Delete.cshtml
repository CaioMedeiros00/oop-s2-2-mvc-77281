@model Food.Domain.Models.Premises

@{
    ViewData["Title"] = "Delete Premises";
}

<h1>Delete Premises</h1>

<h3>Are you sure you want to delete this premises?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3">Address</dt>
        <dd class="col-sm-9">@Model.Address</dd>

        <dt class="col-sm-3">Town</dt>
        <dd class="col-sm-9">@Model.Town</dd>

        <dt class="col-sm-3">Risk Rating</dt>
        <dd class="col-sm-9">@Model.RiskRating</dd>

        <dt class="col-sm-3">Inspections</dt>
        <dd class="col-sm-9">@Model.Inspections.Count</dd>
    </dl>
    
    @if (Model.Inspections.Any())
    {
        <div class="alert alert-warning">
            <strong>Warning!</strong> This premises has @Model.Inspections.Count inspection(s). Deleting it will also delete all related inspections and follow-ups.
        </div>
    }
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
